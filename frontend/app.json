{
  "expo": {
    "name": "DanoFitness23",
    "slug": "danofitness23",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "danofitness",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "owner": "danofitness",
    "extra": {
      "eas": {
        "projectId": "danofitness23-push"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.danofitness.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Scatta foto per il tuo profilo",
        "NSPhotoLibraryUsageDescription": "Seleziona foto per il tuo profilo"
      }
    },
    "android": {
      "package": "com.danofitness.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1A1A2E"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "DanoFitness23",
      "shortName": "DanoFitness",
      "description": "App prenotazioni lezioni fitness DanoFitness23",
      "backgroundColor": "#1A1A2E",
      "themeColor": "#FF6B35",
      "splash": {
        "image": "./assets/images/icon-512.png",
        "resizeMode": "contain",
        "backgroundColor": "#1A1A2E"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1A1A2E"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon-192.png",
          "color": "#FF6B35"
        }
      ]
    ],
    "notification": {
      "icon": "./assets/images/icon-192.png",
      "color": "#FF6B35",
      "androidMode": "default",
      "androidCollapsedTitle": "DanoFitness23"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
